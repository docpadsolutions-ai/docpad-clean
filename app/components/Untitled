"use client";
import { useState, useEffect } from "react";

export default function SnomedSearch({
  placeholder,
  onSelect
}: {
  placeholder: string;
  onSelect: (concept: { term: string; conceptId: string; icd10: string | null }) => void;
}) {
  const [query, setQuery] = useState("");
  const [results, setResults] = useState<any[]>([]);
  const [isOpen, setIsOpen] = useState(false);
  const [isLoading, setIsLoading] = useState(false);

  // Debounce the API call so we don't spam the server on every keystroke
  useEffect(() => {
    if (query.length < 2) {
      setResults([]);
      setIsOpen(false);
      return;
    }

    const delayDebounceFn = setTimeout(async () => {
      setIsLoading(true);
      try {
        const res = await fetch(`/api/snomed/search?q=${encodeURIComponent(query)}`);
        const data = await res.json();
        if (data.results) {
          setResults(data.results);
          setIsOpen(true);
        }
      } catch (error) {
        console.error("SNOMED search failed", error);
      } finally {
        setIsLoading(false);
      }
    }, 300); // Waits 300ms after you stop typing

    return () => clearTimeout(delayDebounceFn);
  }, [query]);

  return (
    <div className="relative w-full">
      <input
        type="text"
        className="w-full rounded-lg border border-gray-300 p-3 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 shadow-sm"
        placeholder={placeholder}
        value={query}
        onChange={(e) => setQuery(e.target.value)}
      />

      {isOpen && results.length > 0 && (
        <ul className="absolute z-50 mt-1 max-h-60 w-full overflow-auto rounded-lg border border-gray-200 bg-white py-1 shadow-xl">
          {results.map((item) => (
            <li
              key={item.conceptId}
              className="cursor-pointer px-4 py-2 hover:bg-blue-50"
              onClick={() => {
                // 1. Show the plain text to the doctor in the UI
                setQuery(item.term); 
                setIsOpen(false);
                // 2. Send the invisible codes back to the parent form for saving
                onSelect(item);      
              }}
            >
              <div className="font-medium text-gray-900">{item.term}</div>
              <div className="text-xs text-gray-500">
                SNOMED: {item.conceptId} {item.icd10 && `• ICD-10: ${item.icd10}`}
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  );
}